              "rawSql": "SELECT\n  toStartOfMinute(parseDateTime64BestEffort(JSONExtractString(payload, 'timestamp'))) AS time,\n  countIf(JSONExtractString(payload, 'action') = 'add') AS adds,\n  countIf(JSONExtractString(payload, 'action') = 'del') AS deletes\nFROM bmp.gobmp_unicast_prefix_v4\nWHERE\n  JSONExtractBool(payload, 'is_ipv4') = true\n  AND $__timeFilter(parseDateTime64BestEffort(JSONExtractString(payload, 'timestamp')))\n  AND concat(JSONExtractString(payload, 'prefix'), '/', toString(JSONExtractUInt(payload, 'prefix_len'))) = ${prefix_cidr:singlequote}\nGROUP BY time\nORDER BY time\n",
